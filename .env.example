# Frontend
NEXT_PUBLIC_SITE_URL=https://allfilesconvertor.com
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Backend
FRONTEND_URL=http://localhost:3000
TEMP_STORAGE=local
MAX_FILE_MB=100
MAX_BATCH_FILES=20
MAX_BATCH_MB=250
MAX_OUTPUT_MB=500
BATCH_CONCURRENCY=3
CLEANUP_TTL_MINUTES=10
TEMP_FILE_TTL_MINUTES=60
CLEANUP_INTERVAL_SECONDS=300
ANALYTICS_PATH=/tmp/all_files_convertor_analytics.json
LIBREOFFICE_BIN=/opt/homebrew/bin/soffice
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_RETENTION_HOURS=24
TRUST_PROXY_HEADERS=false
REDIS_URL=redis://localhost:6379/0
SENTRY_DSN=
